# Public site URL
NEXT_PUBLIC_SITE_URL=https://www.aliwvide.com

# Supabase public read access
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase server-only write access. Never expose this in frontend code.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Hidden admin login
ADMIN_USERNAME=your_admin_username
ADMIN_PASSWORD=your_admin_password
ADMIN_SESSION_SECRET=replace_with_a_long_random_secret

# n8n route secret used by POST /api/n8n/blogs
N8N_API_SECRET=replace_with_a_long_random_secret

# Contact form is hardcoded in src/components/ContactForm.jsx
# Current endpoint: https://formspree.io/f/xqenywva

# Hidden admin URL after deploy:
# https://www.aliwvide.com/secure-aliwvide-control-9xq2m
